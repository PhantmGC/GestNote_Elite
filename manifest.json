{
  "manifest_version": 3,
  "name": "GestNote Elite",
  "version": "1.0.0",
  "description": "Affiche moyenne de classe, rang et histogramme de r\u00e9partition \u00e0 partir des donn\u00e9es d\u00e9j\u00e0 pr\u00e9sentes dans la page de notes.",
  "browser_specific_settings": {
    "gecko": {
      "id": "gestnote-elite@exemple.fr",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "host_permissions": [
    "https://scolarite.polytech.univ-nantes.fr/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://scolarite.polytech.univ-nantes.fr/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "48": "GestNote_Elite-48x48.png",
    "96": "GestNote_Elite-96x96.png"
  },
  "action": {
    "default_icon": {
      "48": "GestNote_Elite-48x48.png",
      "96": "GestNote_Elite-96x96.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "GestNote_Elite-128x128.png"
      ],
      "matches": [
        "https://scolarite.polytech.univ-nantes.fr/*"
      ]
    }
  ]
}
